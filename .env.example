# ============== Django 核心配置 ==============
# 生产环境务必修改 DJANGO_SECRET_KEY 为随机字符串
DJANGO_SECRET_KEY=django-insecure-please-change-this-key-in-production-env
DJANGO_DEBUG=True

# ============== 数据库 ==============
# 留空则使用 SQLite, 设置为 mysql 则使用 MySQL
DB_ENGINE=
DB_NAME=inventory_db
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# ============== 部署监听 ==============
# 仅 DEBUG=True 时使用, 生产环境建议通过 Nginx 反向代理
ALLOWED_HOSTS=localhost,127.0.0.1
